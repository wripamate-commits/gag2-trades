<script>
// აჩვენებს კონტაქტის ბოქსს
function showContact(button){
    const box = button.parentElement.querySelector(".contact-box");
    box.style.display = "block";
    button.style.display = "none"; // მალავს "Trade Me" ღილაკს გახსნის შემდეგ
}

// აკეთებს კონკრეტული იუზერნეიმის კოპირებას დინამიურად
function copyUser(button){
    const usernameText = button.parentElement.querySelector(".username").innerText;
    navigator.clipboard.writeText(usernameText);
    
    // ვიზუალური ეფექტი ალერტის ნაცვლად (უფრო ლამაზია)
    const originalText = button.innerText;
    button.innerText = "✓ Copied!";
    button.style.background = "#22c55e";
    
    setTimeout(() => {
        button.innerText = originalText;
        button.style.background = "#3b82f6";
    }, 2000);
}

// ძებნის ფუნქცია
document.getElementById("search").addEventListener("keyup", function(){
    let value = this.value.toLowerCase();
    
    document.querySelectorAll(".trade-card").forEach(card => {
        // ეძებს მხოლოდ ტექსტში (იუზერნეიმის და კოპირების ტექსტის გარეშე)
        let title = card.querySelector("h3").innerText.toLowerCase();
        let desc = card.querySelector("p").innerText.toLowerCase();
        
        if(title.includes(value) || desc.includes(value)) {
            card.style.display = "flex";
        } else {
            card.style.display = "none";
        }
    });
});
</script>

